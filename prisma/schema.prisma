// QtechVending — Prisma schema (independent database `qtechvending`)
// This schema is intentionally Lean: NO e-commerce models (Order/Payment/Cart/
// Favorite/Review/Tag) — the site is a B2B showcase + inquiry portal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 分类（11 个 product_cat）====================
model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        Json     // { zh, en, ar }
  icon        String?  // emoji 或图标名
  description Json?
  order       Int      @default(0)
  status      String   @default("active") // active
  type        String   @default("product") // product
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[] @relation(map: "ProductCategory")
  @@index([type, status])
  @@map("categories")
}

// ==================== 产品 ====================
model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  sku              String   @unique
  name             Json     // { zh, en, ar }
  displayTitle     Json?    // { zh, en, ar } 简短展示名（详情页 H1 用，避免 SEO 长尾标题）
  description      Json?    // { zh, en, ar } 正文
  shortDescription Json?    // { zh, en, ar } 列表简述
  images           String[] // 本地路径数组：/images/products/<slug>/1.webp
  features         Json?    // { en:[], zh:[], ar:[] } 卖点
  specs            Json?    // 参数表：[{ param: string, value: string }]
  status           String   @default("active") // active
  featured         Boolean  @default(false)
  order            Int      @default(0)
  relatedProducts  String[] // Product id 数组
  seoTitle         Json?
  seoDescription   Json?
  seoKeywords      Json?
  faq              Json?    // [{ q: { en, zh, ar }, a: { en, zh, ar } }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  categories       Category[] @relation(map: "ProductCategory")
  @@index([status, featured])
  @@index([slug])
  @@map("products")
}

// ==================== 博客 ====================
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       Json     // { zh, en, ar }
  excerpt     Json?    // { zh, en, ar }
  content     Json     // { zh, en, ar } Markdown
  author      String   @default("Qtech Team")
  publishedAt DateTime
  status      String   @default("published") // published
  featured    Boolean  @default(false)
  images      String[] @default([]) // V51: 多图，首张 images[0] 为封面
  seoKeywords Json?
  seoTitle    Json?    // { zh, en, ar } — distinct SERP title from the on-page H1
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status, publishedAt])
  @@map("blog_posts")
}

// ==================== 公司介绍（关于页结构化内容）====================
model CompanyInfo {
  id        String   @id @default(cuid())
  slug      String   @unique @default("main")
  sections  Json?    // [{ key, title:{zh,en,ar}, body:{zh,en,ar}, image? }]
  updatedAt DateTime @updatedAt
  @@map("company_info")
}

// ==================== 联系询盘消息 ====================
model ContactMessage {
  id              Int      @id @default(autoincrement())
  name            String
  email           String
  phone           String?
  company         String?  // 公司
  country         String?  // 国家
  productInterest String?  // 产品/分类兴趣（slug）
  subject         String   // general|sales|support|customization|partnership
  message         String   @db.Text
  isRead          Boolean  @default(false)
  locale          String   @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([createdAt])
  @@index([isRead])
  @@map("contact_messages")
}

// ==================== 后台用户（仅 admin 登录）====================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin") // admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("users")
}

// ==================== 站点设置（迁移自 SITE_CONFIG）====================
// 单例行：slug = 'main'。标题/公司/地址等多语言字段统一为 { en, zh, ar }。
// 注：V49.22 废弃了最初设计中的 defaultTitleZh 字段，标题统一用 defaultTitle Json。
model SiteSetting {
  id                String   @id @default(cuid())
  slug              String   @unique @default("main")
  company           Json     // { en, zh, ar } 公司全称
  email             String
  phone             String
  address           Json?    // { en, zh, ar } 地址文本
  addressLine       String?  // 简版地址（页脚/地图用，单语）
  socials           Json?    // [{ name, href }] 社交链接
  sameAs            Json?    // string[] 品牌社媒 URL 列表
  ogImage           String?  @default("/images/og-default.svg")
  twitterHandle     String?  @default("@qtechvending")
  keywords          Json?    // { en:[], zh:[], ar:[] }
  defaultTitle      Json?    // { en, zh, ar }
  defaultDescription Json?   // { en, zh, ar }
  // V52: multi-domain SSL certificate management. Replaces the V51 single-group
  // sslCertPath/sslKeyPath/sslEnabled fields (retained as deprecated columns
  // below for backwards compatibility — they are no longer read or written).
  forceHttps        Boolean  @default(true)  // global HTTPS enforcement (edge 308 redirect)
  sslCerts          Json     @default("[]")  // V52: [{ domain, certPath, keyPath, enabled }]
  // --- V51 single-group SSL fields: DEPRECATED, retained for column compat only ---
  sslCertPath       String?  // deprecated — prefer sslCerts[].certPath
  sslKeyPath        String?  // deprecated — prefer sslCerts[].keyPath
  sslEnabled        Boolean  @default(false) // deprecated — prefer sslCerts[].enabled
  updatedAt         DateTime @updatedAt
  @@map("site_settings")
}

// ==================== 全局 FAQ 分类 ====================
model SiteFaqCategory {
  id        String        @id @default(cuid())
  key       String        @unique // 稳定标识：general / technical / order-support
  title     Json          // { en, zh, ar }
  faqOrder  Int           @default(0)
  items     SiteFaqItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([faqOrder])
  @@map("site_faq_categories")
}

// ==================== 全局 FAQ 条目 ====================
model SiteFaqItem {
  id          String          @id @default(cuid())
  categoryId  String
  category    SiteFaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "SiteFaqItemCategory")
  question    Json            // { en, zh, ar }
  answer      Json            // { en, zh, ar }
  faqOrder    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([categoryId, faqOrder])
  @@map("site_faq_items")
}
