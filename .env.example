# ============================================================
# QtechVending environment variables (example)
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# --- Database (INDEPENDENT PostgreSQL database `qtechvending`) ---
# The app talks ONLY to the qtechvending database — it never touches smart_cabinet.
DATABASE_URL="postgresql://qtechvending_user:qtechvending_password@localhost:5432/qtechvending"

# --- Runtime port (pm2 injects 3001; local scripts also use 3001) ---
PORT=3001

# --- Admin JWT secret for the /xiaozhouBackend contact-message console ---
ADMIN_JWT_SECRET="change-me-to-a-long-random-string"

# --- Canonical base URL (used for canonical/hreflang/og JSON-LD) ---
# Production (www): https://www.qtechvending.com
# Staging (test):   https://test.qtechvending.com
NEXT_PUBLIC_BASE_URL="https://www.qtechvending.com"

# --- Inquiry notification email (optional; if unset, email is skipped, DB write still succeeds) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="sales@qtechvending.com"
ADMIN_TO="sales@qtechvending.com"
